---
import ThemeToggle from './ThemeToggle.astro';
import KurashiMark from './KurashiMark.astro';
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'kurashinotes';
const navItems = [
  { label: 'ホーム', href: '/' },
  { label: '記事一覧', href: '/posts/' },
  { label: '季節', href: '/categories/' },
  { label: 'このサイトについて', href: '/about/' },
];
---
<header class="sticky top-0 z-50 border-b backdrop-blur-xl" style="border-color: var(--line); background: color-mix(in srgb, var(--paper) 88%, transparent);">
  <div class="wrap flex min-h-[72px] items-center justify-between gap-6">
    <a href="/" class="group flex min-w-0 items-center gap-3 text-[var(--ink)]" aria-label={`${siteName} ホーム`}>
      <span class="grid h-10 w-10 shrink-0 place-items-center transition-colors group-hover:text-[var(--terra)]"><KurashiMark class="h-10 w-10" /></span>
      <span class="min-w-0 leading-none">
        <span class="block text-xl font-black tracking-[.08em] md:text-2xl" style="font-family: var(--font-heading);">暮らしノート</span>
        <span class="mt-1 block text-[9px] font-bold uppercase tracking-[.34em] text-[var(--ink-soft)]" style="font-family: var(--font-latin);">KURASHINOTES</span>
      </span>
    </a>
    <nav aria-label="主要ナビゲーション" class="hidden md:block">
      <ul class="flex items-center gap-7 text-sm font-medium tracking-[.08em] text-[var(--ink)]">
        {navItems.map((item) => <li><a class="hover:text-[var(--terra)] transition-colors" href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>
    <div class="flex items-center gap-3 text-[var(--ink-soft)]">
      <a href="/search/" class="grid h-11 w-11 place-items-center rounded-full hover:bg-[var(--terra-wash)] hover:text-[var(--terra-deep)]" aria-label="検索">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8"/><path d="M16.5 16.5L21 21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
      </a>
      <button type="button" data-bookmark-drawer class="hidden sm:grid h-11 w-11 place-items-center rounded-full hover:bg-[var(--terra-wash)] hover:text-[var(--terra-deep)]" aria-label="保存した記事">
        <svg width="21" height="21" viewBox="0 0 24 24" fill="none"><path d="M7 4.5h10v15l-5-3-5 3v-15Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
      </button>
      <ThemeToggle />
    </div>
  </div>
  <nav aria-label="モバイル主要ナビゲーション" class="border-t md:hidden" style="border-color: var(--line);">
    <ul class="wrap flex gap-2 overflow-x-auto py-2 text-xs font-medium tracking-[.08em] [-webkit-overflow-scrolling:touch]">
      {navItems.map((item) => <li class="shrink-0"><a class="inline-flex min-h-10 items-center rounded-full border px-4" style="border-color:var(--line); background:var(--paper);" href={item.href}>{item.label}</a></li>)}
      <li class="shrink-0"><a class="inline-flex min-h-10 items-center rounded-full border px-4" style="border-color:var(--line); background:var(--paper);" href="/search/">検索</a></li>
    </ul>
  </nav>
</header>
