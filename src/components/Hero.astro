---
export interface Props { title: string; subtitle: string; ctaText?: string; ctaHref?: string; }
const { ctaText = '記事を読む', ctaHref = '#latest' } = Astro.props;
---
<section class="relative overflow-hidden border-b" style="border-color:var(--line); background:var(--canvas);">
  <div class="wrap grid gap-10 py-16 md:grid-cols-[1.05fr_.95fr] md:items-center md:py-20 lg:py-24">
    <div>
      <p class="k-label mb-7">Seasonal Living Guide</p>
      <h1 class="max-w-[12ch] text-5xl font-black leading-[1.22] tracking-[.04em] text-[var(--ink)] md:text-6xl lg:text-7xl" style="font-family:var(--font-heading);">小さな暮らしを、<br/>ていねいに。</h1>
      <p class="mt-8 max-w-xl text-lg leading-9 text-[var(--ink-soft)]">小さな工夫と季節のしつらえで、住まいをここちよく。<br class="hidden sm:block"/>季節のしつらえと、むりのない家しごとのヒントを。</p>
      <div class="mt-9 flex flex-wrap items-center gap-4">
        <a href={ctaHref} class="btn-primary">{ctaText}<span aria-hidden="true" class="ml-2">→</span></a>
        <a href="/posts/" class="btn-secondary">ニュースレター</a>
      </div>
    </div>
    <a href={ctaHref} class="group block min-w-0" aria-label="おすすめ記事へ">
      <div class="motif-field aspect-[4/3] shadow-[0_30px_90px_-55px_rgba(43,39,34,.55)]">
        <span class="absolute left-7 top-7 z-10 rounded-full bg-[var(--terra)] px-5 py-2 text-sm font-bold text-white">編集部のおすすめ</span>
        <div class="absolute inset-x-0 bottom-0 z-10 p-8 text-white" style="background:linear-gradient(transparent, rgba(43,39,34,.55));">
          <p class="mb-4 text-xs font-bold uppercase tracking-[.22em]" style="font-family:var(--font-latin);">Storage · 整理・収納</p>
          <h2 class="text-3xl font-bold leading-snug tracking-[.06em]">衣替えのいらない、クローゼットのつくり方</h2>
          <p class="mt-4 text-sm opacity-90">9 min read · 2026.05.28</p>
        </div>
      </div>
    </a>
  </div>
</section>
