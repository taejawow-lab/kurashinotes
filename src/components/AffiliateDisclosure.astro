---
const lang = import.meta.env.PUBLIC_SITE_LANG || 'ja';
const text = lang === 'ko'
  ? '쿠팡파트너스 활동의 일환으로 일정액의 수수료를 제공받을 수 있습니다. 모든 추천은 협찬·광고비를 받지 않은 데이터 기반 비교에 기반합니다.'
  : lang === 'ja'
    ? 'この記事にはアフィリエイトリンクが含まれる場合があります。対象商品を購入すると、当サイトが紹介料を受け取ることがあります。おすすめは広告費ではなく、一次資料と比較データに基づいて選定しています。'
    : 'This article contains affiliate links. As an affiliate partner, we may earn from qualifying purchases. All recommendations are based on data-driven comparisons, not paid placements.';
const label = lang === 'ko'
  ? '⚖️ 어필리에이트 고지'
  : lang === 'ja'
    ? '⚖️ アフィリエイト開示'
    : '⚖️ Affiliate Disclosure';
---

<aside class="affiliate-disclosure" role="note" aria-label={label}>
  <strong class="block mb-1">
    {label}
  </strong>
  <p>{text}</p>
</aside>
