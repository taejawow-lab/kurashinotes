---
export interface Props { title:string; description:string; href:string; image?:string; category?:string; pubDate:Date; readingTime?:number; variant?:'feature'|'standard'; index?:number; }
const { title, description, href, image, category, pubDate, readingTime = 7, variant='standard', index=0 } = Astro.props;
const colors=['','motif-blue','','motif-green','motif-pink'];
const motif=colors[index % colors.length];
const date=pubDate.toLocaleDateString('ja-JP', { year:'numeric', month:'2-digit', day:'2-digit' }).replaceAll('/','.');
---
<article class={`group ${variant === 'feature' ? 'md:col-span-2' : ''}`}>
  <div class="relative">
    <button type="button" data-bookmark data-title={title} data-url={href.endsWith('/') ? href : `${href}/`} class="absolute right-4 top-4 z-20 grid h-10 w-10 place-items-center rounded-full bg-[rgba(251,248,243,.82)] text-[var(--ink-soft)] backdrop-blur hover:text-[var(--terra)]" aria-label={`保存 ${title}`}>♡</button>
    <a href={href.endsWith('/') ? href : `${href}/`} class="block no-underline">
      {image ? (
        <div class={`motif-field ${motif} ${variant === 'feature' ? 'aspect-[16/10]' : 'aspect-[3/2]'} mb-5`}>
          <img src={image} alt={title} loading="lazy" decoding="async" class="h-full w-full object-cover opacity-[.42] mix-blend-multiply transition-transform duration-700 group-hover:scale-[1.025]" />
          {category && <span class="absolute bottom-5 left-5 z-10 rounded-full bg-[var(--paper)] px-4 py-2 text-xs font-bold text-[var(--ink)] shadow-sm">{category}</span>}
        </div>
      ) : (
        <div class={`motif-field ${motif} ${variant === 'feature' ? 'aspect-[16/10]' : 'aspect-[3/2]'} mb-5`}>{category && <span class="absolute bottom-5 left-5 z-10 rounded-full bg-[var(--paper)] px-4 py-2 text-xs font-bold text-[var(--ink)] shadow-sm">{category}</span>}</div>
      )}
      <p class="mb-3 text-xs font-bold uppercase tracking-[.22em] text-[var(--terra)]" style="font-family:var(--font-latin);">{category || 'Living'}</p>
      <h3 class={`${variant === 'feature' ? 'text-3xl md:text-4xl' : 'text-xl md:text-2xl'} mb-3 font-bold leading-[1.55] tracking-[.05em] text-[var(--ink)] transition-colors group-hover:text-[var(--terra-deep)]`}>{title}</h3>
      <p class="line-clamp-3 text-[15px] leading-8 text-[var(--ink-soft)]">{description}</p>
      <div class="mt-5 flex items-center gap-2 text-xs text-[var(--ink-faint)]"><span>◷</span><span>{readingTime} min</span><span>•</span><time datetime={pubDate.toISOString()}>{date}</time></div>
    </a>
  </div>
</article>
