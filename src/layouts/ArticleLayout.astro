---
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/TOC.astro';
import References from '../components/References.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
  category?: string;
  sources?: Array<{ title: string; url: string; author?: string; year?: string }>;
  affiliate?: boolean;
  visualsCount?: number;
  hasVideo?: boolean;
  headings?: Array<{ depth: number; slug: string; text: string }>;
  faq?: Array<{ question: string; answer: string }>;
  internalLinks?: string[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags = [],
  category,
  sources = [],
  affiliate = false,
  visualsCount = 0,
  hasVideo = false,
  headings = [],
  faq = [],
  internalLinks = [],
} = Astro.props;

const articleSchema = {
  '@type': 'Article',
  headline: title,
  description,
  image: heroImage,
  datePublished: pubDate?.toISOString(),
  dateModified: (updatedDate || pubDate)?.toISOString(),
  author: {
    '@type': 'Organization',
    name: import.meta.env.PUBLIC_SITE_NAME + ' Editorial Team',
    url: import.meta.env.PUBLIC_SITE_URL,
  },
  publisher: {
    '@type': 'NewsMediaOrganization',
    name: import.meta.env.PUBLIC_SITE_NAME,
    url: import.meta.env.PUBLIC_SITE_URL,
  },
};

const faqSchema = faq.length > 0 ? {
  '@type': 'FAQPage',
  mainEntity: faq.map((q) => ({
    '@type': 'Question',
    name: q.question,
    acceptedAnswer: { '@type': 'Answer', text: q.answer },
  })),
} : null;

const siteUrlBC = (Astro.site ? Astro.site.toString().replace(/\/$/, '') : (import.meta.env.PUBLIC_SITE_URL || 'https://kurashinotes.com'));
const siteNameBC = import.meta.env.PUBLIC_SITE_NAME || 'Editorial';
const postUrlBC = `${siteUrlBC}${Astro.url.pathname}`;
const categorySlug = category ? category.toLowerCase().trim().replace(/\s+/g, '-') : '';
const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: siteNameBC, item: `${siteUrlBC}/` },
    ...(category ? [{ '@type': 'ListItem', position: 2, name: category, item: `${siteUrlBC}/category/${categorySlug}/` }] : []),
    { '@type': 'ListItem', position: (category ? 3 : 2), name: title, item: postUrlBC },
  ],
};

const schema = faqSchema ? {
  '@context': 'https://schema.org',
  '@graph': [articleSchema, breadcrumbSchema, faqSchema],
} : { '@context': 'https://schema.org', '@graph': [articleSchema, breadcrumbSchema] };

const lang = import.meta.env.PUBLIC_SITE_LANG || 'en';
const localeMap: Record<string, string> = { ko: 'ko-KR', ja: 'ja-JP', en: 'en-US' };
const tMap: Record<string, { published: string; updated: string; sources: string; visuals: string; video: string; related: string; explore: string }> = {
  ko: { published: '발행일', updated: '갱신', sources: '건 1차 자료', visuals: '종 시각 자료', video: '영상 요약', related: '함께 읽으면 좋은 글', explore: '관련 경로 열기' },
  ja: { published: '公開', updated: '更新', sources: '件の出典', visuals: '点のビジュアル', video: '動画要約', related: 'あわせて読みたい', explore: '関連ページを開く' },
  en: { published: 'Published', updated: 'Updated', sources: 'sources cited', visuals: 'visuals', video: 'Video summary', related: 'Related Reading', explore: 'Open related path' },
};
const t = tMap[lang] || tMap.en;
const locale = localeMap[lang] || 'en-US';
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  type="article"
  publishedTime={pubDate?.toISOString()}
  modifiedTime={(updatedDate || pubDate)?.toISOString()}
  schema={schema}
>
  <div class="fixed left-0 top-0 z-[70] h-1 w-full bg-transparent" aria-hidden="true"><div id="reading-progress" class="h-full w-0 bg-[var(--terra)]"></div></div>
  <article class="wrap py-10 md:py-14">
    <header class="mx-auto mb-10 max-w-4xl text-center">
      {category && <a href={`/category/${categorySlug}/`} class="mb-5 inline-flex min-h-9 items-center rounded-full px-4 py-2 text-xs font-bold tracking-[.16em] text-white" style="background:var(--terra);">{category}</a>}
      <h1 class="mb-6 text-4xl font-black leading-[1.28] tracking-[.05em] text-[var(--ink)] md:text-6xl">{title}</h1>
      <p class="mx-auto max-w-3xl text-lg leading-9 text-[var(--ink-soft)] md:text-xl">{description}</p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-3 text-xs text-[var(--ink-faint)]">
        <time datetime={pubDate?.toISOString()} class="rounded-full border px-3 py-2" style="border-color:var(--line);">{t.published} {pubDate?.toLocaleDateString(locale)}</time>
        {updatedDate && updatedDate.getTime() !== pubDate.getTime() && <time datetime={updatedDate.toISOString()} class="rounded-full border px-3 py-2" style="border-color:var(--line);">{t.updated} {updatedDate.toLocaleDateString(locale)}</time>}
        <span class="rounded-full border px-3 py-2" style="border-color:var(--line);">{sources.length} {t.sources}</span>
        {visualsCount > 0 && <span class="rounded-full border px-3 py-2" style="border-color:var(--line);">{visualsCount} {t.visuals}</span>}
        <button type="button" data-bookmark data-title={title} data-url={Astro.url.pathname} class="grid h-10 w-10 place-items-center rounded-full border text-[var(--ink-soft)] hover:text-[var(--terra)]" style="border-color:var(--line);">♡</button>
        <button type="button" data-copy-link class="rounded-full border px-4 py-2 text-[var(--ink-soft)] hover:text-[var(--terra)]" style="border-color:var(--line);">共有</button>
      </div>
    </header>
    {heroImage && <div class="motif-field mb-12 aspect-[16/7]"><img src={heroImage} alt={title} width="1280" height="720" loading="eager" fetchpriority="high" decoding="async" class="h-full w-full object-cover opacity-[.42] mix-blend-multiply" /></div>}
    <script is:inline>
      (() => { const bar=document.getElementById('reading-progress'); const set=()=>{ const max=document.documentElement.scrollHeight-innerHeight; if(bar&&max>0) bar.style.width=Math.min(100, Math.max(0, scrollY/max*100))+'%';}; addEventListener('scroll', set, {passive:true}); set(); document.addEventListener('click',(e)=>{ if(e.target.closest('[data-copy-link]')) navigator.clipboard?.writeText(location.href); }); })();
    </script>
    {affiliate && <AffiliateDisclosure />}
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[210px_minmax(0,1fr)_86px] lg:gap-12">
      {headings.length > 0 && <aside class="hidden lg:block"><div class="sticky top-28 border-l pl-5" style="border-color:var(--line);"><p class="mb-4 text-xs tracking-[.18em] text-[var(--ink-faint)]">☰ もくじ</p><TOC headings={headings} /></div></aside>}
      <div class="prose-article min-w-0"><slot />{sources.length > 0 && <References sources={sources} />}</div>
      <aside class="hidden lg:block"><div class="sticky top-28 flex flex-col gap-3"><button type="button" data-bookmark data-title={title} data-url={Astro.url.pathname} class="grid h-12 w-12 place-items-center rounded-full border text-[var(--ink-soft)] hover:text-[var(--terra)]" style="border-color:var(--line);">♡</button><button type="button" data-copy-link class="grid h-12 w-12 place-items-center rounded-full border text-[var(--ink-soft)] hover:text-[var(--terra)]" style="border-color:var(--line);">↗</button></div></aside>
    </div>
    {internalLinks.length > 0 && <section class="mt-14 rounded-2xl border p-6" style="border-color:var(--line); background:var(--paper);"><h2 class="m-0 mb-5 text-2xl font-bold text-[var(--ink)]">{t.related}</h2><ul class="grid gap-3 sm:grid-cols-2">{internalLinks.map((link)=><li><a href={link} class="flex min-h-12 items-center justify-between rounded-full border px-4 text-sm font-bold text-[var(--ink-soft)] no-underline hover:text-[var(--terra)]" style="border-color:var(--line);"><span class="truncate">{link}</span><span>→</span></a></li>)}</ul></section>}
    {tags.length > 0 && <footer class="mt-12 border-t pt-8" style="border-color:var(--line);"><div class="flex flex-wrap gap-2">{tags.map((tag)=><a href={`/tags/${tag.toLowerCase().trim().replace(/[\/\\&%?#=]/g, '-').replace(/\s+/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '')}/`} class="inline-flex min-h-9 items-center rounded-full border px-3 py-1 text-sm text-[var(--ink-soft)] hover:text-[var(--terra)]" style="border-color:var(--line);">#{tag}</a>)}</div></footer>}
  </article>
</BaseLayout>
