---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ArticleCard from '../components/ArticleCard.astro';
const posts = (await getCollection('posts')).filter((post)=>!post.data.draft).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
const featuredPosts = posts.slice(0,3);
const recentPosts = posts.slice(3,12);
const siteDescription = import.meta.env.PUBLIC_SITE_DESCRIPTION || '';
---
<BaseLayout title="Home" description={siteDescription}>
  <Hero title="小さな暮らしを、ていねいに。" subtitle={siteDescription} ctaHref={`/posts/${posts[0]?.slug}/`} />
  <section class="wrap py-14 md:py-20">
    <div class="grid gap-4 border-b pb-8 md:grid-cols-[220px_1fr] md:items-end" style="border-color:var(--line);">
      <div><p class="k-label">Season</p><h2 class="mt-3 text-3xl font-bold tracking-[.08em] text-[var(--ink)]">季節のしつらえ</h2></div>
      <div class="flex flex-wrap gap-3 md:justify-end">
        {['春の整え','夏の湿気対策','秋の夜長','冬じたく'].map((s)=><a href="/categories/" class="rounded-full border px-4 py-2 text-sm text-[var(--ink-soft)] hover:text-[var(--terra-deep)]" style="border-color:var(--line); background:var(--paper);">{s}</a>)}
      </div>
    </div>
  </section>
  {featuredPosts.length > 0 && <section id="latest" class="wrap pb-16 md:pb-24"><div class="mb-10 flex items-end justify-between gap-5"><div><p class="k-label">Editor’s Picks</p><h2 class="mt-3 text-4xl font-black tracking-[.06em] text-[var(--ink)]">おすすめの記事</h2></div><a href="/posts/" class="hidden border-b text-sm font-bold tracking-[.12em] text-[var(--terra-deep)] md:inline" style="border-color:var(--terra);">記事一覧へ →</a></div><div class="grid gap-x-8 gap-y-14 md:grid-cols-3">{featuredPosts.map((post,i)=><ArticleCard title={post.data.title} description={post.data.description} href={`/posts/${post.slug}/`} image={post.data.heroImage} category={post.data.category} pubDate={post.data.pubDate} variant="standard" index={i} />)}</div></section>}
  <section class="border-t py-16 md:py-24" style="border-color:var(--line);"><div class="wrap"><div class="mb-10 grid gap-3 md:grid-cols-[1fr_auto] md:items-end"><div><p class="k-label">Latest Notes</p><h2 class="mt-3 text-4xl font-black tracking-[.06em] text-[var(--ink)]">新着ノート</h2></div><p class="text-xs uppercase tracking-[.22em] text-[var(--ink-faint)]" style="font-family:var(--font-latin);">{posts.length} preserved guides · sorted by date</p></div><div class="grid gap-x-8 gap-y-14 md:grid-cols-2 lg:grid-cols-3">{recentPosts.map((post,i)=><ArticleCard title={post.data.title} description={post.data.description} href={`/posts/${post.slug}/`} image={post.data.heroImage} category={post.data.category} pubDate={post.data.pubDate} index={i+3} />)}</div></div></section>
</BaseLayout>
